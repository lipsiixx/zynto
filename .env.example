# Скопируй в .env и заполни своими значениями: cp .env.example .env

# --- Telegram ---
BOT_TOKEN=                       # токен @BotFather
SUPERADMIN_ID=                   # твой Telegram ID (числом)

# --- База данных ---
# Для Docker эти две строки переопределяются в docker-compose.yml (db/redis),
# трогать их там не нужно — достаточно задать POSTGRES_PASSWORD ниже.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tgguard
REDIS_URL=redis://localhost:6379/0

# Пароль для контейнера postgres (используется docker-compose)
POSTGRES_PASSWORD=postgres

# --- Хранилище медиа ---
STORAGE_TYPE=local               # local | s3
MEDIA_PATH=./media
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# --- Лимиты и хранение ---
MAX_FILE_SIZE_MB=50
TEXT_RETENTION_DAYS=90
MEDIA_RETENTION_DAYS=30
LOG_LEVEL=INFO
